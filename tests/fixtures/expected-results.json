  "heuristicRules": {
    "H001": {
      "name": "vague_cta_text",
      "category": "cta",
      "severity": "medium",
      "description": "CTAs should have specific, action-oriented text",
      "triggerPatterns": ["Click Here", "Learn More", "Submit", "Go", "Continue", "Next", "More", "Info", "Details", "Here", "Link", "Button", "Read More"]
    },
    "H002": {
      "name": "no_cta_above_fold",
      "category": "cta",
      "severity": "high",
      "description": "At least one CTA should be visible without scrolling"
    },
    "H003": {
      "name": "form_field_overload",
      "category": "form",
      "severity": "high",
      "description": "Forms with more than 5 visible fields create friction",
      "threshold": 5
    },
    "H004": {
      "name": "missing_field_label",
      "category": "form",
      "severity": "medium",
      "description": "Form inputs should have associated labels or placeholders"
    },
    "H005": {
      "name": "no_trust_above_fold",
      "category": "trust",
      "severity": "medium",
      "description": "Trust signals should be visible without scrolling"
    },
    "H006": {
      "name": "no_security_badge",
      "category": "trust",
      "severity": "high",
      "businessTypes": ["ecommerce", "banking", "insurance"],
      "description": "Security badges required on checkout/sensitive pages"
    },
    "H007": {
      "name": "unclear_value_prop",
      "category": "value_prop",
      "severity": "high",
      "description": "H1 should clearly communicate value proposition",
      "genericPatterns": ["Welcome", "Home", "Homepage", "Untitled", "About", "About Us"]
    },
    "H008": {
      "name": "headline_too_long",
      "category": "value_prop",
      "severity": "low",
      "description": "Headlines should be concise (10 words or fewer)",
      "threshold": 10
    },
    "H009": {
      "name": "no_breadcrumbs",
      "category": "navigation",
      "severity": "low",
      "description": "Category/product pages should have breadcrumb navigation",
      "appliesTo": ["product", "category", "subcategory"]
    },
    "H010": {
      "name": "no_search_ecommerce",
      "category": "navigation",
      "severity": "medium",
      "businessTypes": ["ecommerce"],
      "description": "Ecommerce sites should have visible search functionality"
    }
  },
  "accuracyTargets": {
    "SC-013": {
      "description": "Heuristic accuracy target",
      "target": 0.9,
      "note": "90% accuracy on heuristic detection"
    },
    "SC-045": {
      "description": "Business type detection accuracy target",
      "target": 0.8,
      "note": "80% accuracy on business type detection"
    }
  }
}
